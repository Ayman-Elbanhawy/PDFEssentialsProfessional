<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="editor-core.db" />
        <exclude domain="database" path="editor-core.db-shm" />
        <exclude domain="database" path="editor-core.db-wal" />
        <exclude domain="file" path="cache" />
        <exclude domain="file" path="diagnostics" />
